{
  "name": "Skycast",
  "short_name": "Skycast",
  "description": "Installable weather forecast app for current, hourly, and weekly weather.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#101315",
